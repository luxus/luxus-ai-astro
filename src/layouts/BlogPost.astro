---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>

  <body>
    <Header />

    <main>
      <!-- Breadcrumb -->
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <span class="prompt-char" aria-hidden="true">❯</span>
        <a href="/">~</a>
        <span class="sep" aria-hidden="true">/</span>
        <a href="/blog">blog</a>
        <span class="sep" aria-hidden="true">/</span>
        <span class="current">{title}</span>
      </nav>

      <article>
        <!-- Man-page style header -->
        <header class="post-header term-window">
          <div class="term-titlebar">
            <span class="term-dot close" aria-hidden="true"></span>
            <span class="term-dot min"   aria-hidden="true"></span>
            <span class="term-dot max"   aria-hidden="true"></span>
            <span class="term-title">cat ~/blog/{title.toLowerCase().replace(/\s+/g, '-')}.md</span>
          </div>
          <div class="header-body">
            {heroImage && (
              <div class="hero-wrap">
                <Image width={860} height={430} src={heroImage} alt="" class="hero-img" />
              </div>
            )}
            <div class="post-meta">
              <span class="meta-key" aria-hidden="true">date</span>
              <span class="meta-sep" aria-hidden="true">:</span>
              <span class="meta-val">
                <FormattedDate date={pubDate} />
                {updatedDate && (
                  <span class="updated-on">
                    (updated <FormattedDate date={updatedDate} />)
                  </span>
                )}
              </span>
            </div>
            <h1 class="post-title">{title}</h1>
            <div class="title-divider" aria-hidden="true"></div>
          </div>
        </header>

        <!-- Prose content -->
        <div class="prose term-window">
          <div class="term-titlebar">
            <span class="term-dot close" aria-hidden="true"></span>
            <span class="term-dot min"   aria-hidden="true"></span>
            <span class="term-dot max"   aria-hidden="true"></span>
            <span class="term-title">output</span>
          </div>
          <div class="prose-body">
            <slot />
          </div>
        </div>

        <!-- Back link -->
        <div class="back-wrap">
          <a href="/blog" class="back-cmd">
            <span class="back-prompt" aria-hidden="true">❯</span>
            <span>cd ..</span>
            <span class="back-label">back to blog</span>
          </a>
        </div>
      </article>
    </main>

    <Footer />
  </body>
</html>

<style>
  body {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  main {
    flex: 1;
    max-width: 860px;
    margin: 0 auto;
    width: 100%;
    padding: 2.5rem 1.5rem 4rem;
  }

  /* Breadcrumb */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    margin-bottom: 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    flex-wrap: wrap;
    row-gap: 0.2rem;
  }

  .prompt-char {
    color: var(--green);
    font-weight: 700;
    text-shadow: 0 0 8px var(--green-glow);
    flex-shrink: 0;
  }

  .breadcrumb a {
    color: var(--text-muted);
    text-decoration: none;
    border-bottom: none;
    transition: color 0.15s;
  }

  .breadcrumb a:hover {
    color: var(--green);
    border-bottom: none;
    text-shadow: 0 0 6px var(--green-glow);
  }

  .sep {
    color: var(--border);
    opacity: 0.6;
  }

  .current {
    color: var(--text-muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 36ch;
  }

  /* Article */
  article {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* Post header */
  .post-header {
    overflow: hidden;
  }

  .header-body {
    padding: 1.5rem;
  }

  .hero-wrap {
    margin: -1.5rem -1.5rem 1.5rem;
    overflow: hidden;
  }

  .hero-img {
    width: 100%;
    height: auto;
    max-height: 360px;
    object-fit: cover;
    border-radius: 0;
    border: none;
    border-bottom: 1px solid var(--border);
    display: block;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }

  .meta-key {
    color: var(--text-muted);
    letter-spacing: 0.05em;
  }

  .meta-sep {
    color: var(--border);
  }

  .meta-val {
    color: var(--text-muted);
    font-variant-numeric: tabular-nums;
  }

  .updated-on {
    margin-left: 0.5rem;
    opacity: 0.6;
    font-style: italic;
  }

  .post-title {
    font-family: var(--font-mono);
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--green);
    text-shadow:
      0 0 8px var(--green-glow),
      0 0 24px rgba(57, 255, 20, 0.12);
    margin: 0 0 1rem 0;
    line-height: 1.25;
    text-wrap: balance;
  }

  .title-divider {
    height: 1px;
    background: linear-gradient(90deg, var(--green-dim), transparent 60%);
    opacity: 0.4;
  }

  /* Prose */
  .prose {
    overflow: hidden;
  }

  .prose-body {
    padding: 2rem;
    font-size: 0.9rem;
    line-height: 1.8;
    color: var(--text);
  }

  /* Headings inside prose */
  .prose-body :global(h1),
  .prose-body :global(h2),
  .prose-body :global(h3),
  .prose-body :global(h4) {
    color: var(--green);
    font-family: var(--font-mono);
    text-shadow: 0 0 10px var(--green-glow);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .prose-body :global(h2)::before {
    content: '## ';
    opacity: 0.4;
  }

  .prose-body :global(h3)::before {
    content: '### ';
    opacity: 0.4;
  }

  .prose-body :global(a) {
    color: var(--amber);
    border-bottom: 1px solid rgba(255, 183, 0, 0.25);
    text-decoration: none;
    transition: color 0.15s, border-color 0.15s, text-shadow 0.15s;
  }

  .prose-body :global(a:hover) {
    color: var(--amber);
    border-bottom-color: var(--amber);
    text-shadow: 0 0 8px var(--amber-glow);
  }

  .prose-body :global(p) {
    margin-bottom: 1.4em;
    color: var(--text);
    text-wrap: pretty;
  }

  .prose-body :global(code) {
    background: var(--green-faint);
    border: 1px solid var(--border);
    color: var(--green);
    font-family: var(--font-mono);
    font-size: 0.85em;
    padding: 0.15em 0.45em;
    border-radius: 3px;
  }

  .prose-body :global(pre) {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1.25em 1.5em;
    overflow-x: auto;
    margin: 1.5em 0;
    position: relative;
  }

  .prose-body :global(pre > code) {
    all: unset;
    font-family: var(--font-mono);
    font-size: 0.85em;
    color: var(--text);
  }

  .prose-body :global(blockquote) {
    border-left: 3px solid var(--green);
    padding: 0.6em 1.25em;
    margin: 1.5em 0;
    color: var(--text-muted);
    font-style: italic;
    background: var(--green-faint);
    border-radius: 0 4px 4px 0;
  }

  .prose-body :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2.5em 0;
  }

  .prose-body :global(img) {
    max-width: 100%;
    border-radius: 4px;
    border: 1px solid var(--border);
    margin: 1em 0;
    display: block;
  }

  .prose-body :global(ul),
  .prose-body :global(ol) {
    padding-left: 1.5em;
    margin: 1em 0;
  }

  .prose-body :global(li) {
    margin-bottom: 0.4em;
    color: var(--text);
  }

  .prose-body :global(li::marker) {
    color: var(--green-dim);
  }

  /* Back link */
  .back-wrap {
    padding-top: 0.5rem;
  }

  .back-cmd {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
    text-decoration: none;
    border-bottom: none;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    background: var(--bg-raised);
    transition: color 0.15s, border-color 0.15s, background 0.15s, text-shadow 0.15s;
  }

  .back-cmd:hover {
    color: var(--green);
    border-color: var(--green-dim);
    background: var(--green-faint);
    text-shadow: 0 0 6px var(--green-glow);
    border-bottom: none;
  }

  .back-prompt {
    color: var(--green-dim);
    font-weight: 700;
  }

  .back-label {
    font-size: 0.7rem;
    opacity: 0.5;
    margin-left: 0.25rem;
  }

  @media (max-width: 600px) {
    main { padding: 1.5rem 1rem 3rem; }

    .post-title { font-size: 1.3rem; }

    .prose-body { padding: 1.25rem; }

    .current { max-width: 18ch; }
  }
</style>

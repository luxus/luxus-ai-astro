---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
  <nav aria-label="Main navigation">
    <div class="nav-left">
      <span class="prompt-char" aria-hidden="true">❯</span>
      <a href="/" class="site-title" aria-label="Home — {SITE_TITLE}">
        {SITE_TITLE}<span class="cursor" aria-hidden="true"></span>
      </a>
    </div>
    <div class="nav-links">
      <HeaderLink href="/">~/home</HeaderLink>
      <HeaderLink href="/blog">~/blog</HeaderLink>
      <HeaderLink href="/about">~/about</HeaderLink>
    </div>
  </nav>
</header>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(12, 12, 12, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 860px;
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
    gap: 1rem;
  }

  .nav-left {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .prompt-char {
    color: var(--green);
    font-size: 1rem;
    font-weight: 700;
    text-shadow: 0 0 8px var(--green-glow);
    line-height: 1;
  }

  .site-title {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 700;
    color: var(--green);
    text-decoration: none;
    letter-spacing: 0.04em;
    border-bottom: none;
    text-shadow: 0 0 10px var(--green-glow);
    transition: text-shadow 0.2s;
  }

  .site-title:hover {
    text-shadow: 0 0 18px var(--green-glow), 0 0 40px rgba(57, 255, 20, 0.15);
    border-bottom: none;
  }

  /* Cursor in title */
  .cursor {
    display: inline-block;
    width: 0.55em;
    height: 0.9em;
    background: var(--green);
    vertical-align: baseline;
    margin-left: 2px;
    border-radius: 1px;
    animation: blink 1.1s step-start infinite;
    box-shadow: 0 0 6px var(--green-glow);
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  :global(.nav-links a) {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
    text-decoration: none;
    border-bottom: none;
    padding: 0.35rem 0.65rem;
    border-radius: 4px;
    border: 1px solid transparent;
    letter-spacing: 0.02em;
    transition: color 0.15s, background 0.15s, border-color 0.15s, text-shadow 0.15s;
  }

  :global(.nav-links a:hover) {
    color: var(--green);
    background: var(--green-faint);
    border-color: var(--border);
    text-shadow: 0 0 8px var(--green-glow);
  }

  :global(.nav-links a.active) {
    color: var(--green);
    background: var(--green-faint);
    border-color: var(--border);
    text-shadow: 0 0 8px var(--green-glow);
  }

  @media (max-width: 520px) {
    nav { padding: 0.65rem 1rem; }

    :global(.nav-links a) { font-size: 0.75rem; padding: 0.3rem 0.5rem; }
  }
</style>

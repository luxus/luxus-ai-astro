---
const today = new Date();
const uptime = `${today.getFullYear()}`;
---

<footer>
  <div class="status-bar">
    <div class="status-left">
      <span class="status-indicator" aria-hidden="true"></span>
      <span class="status-text">ONLINE</span>
      <span class="sep" aria-hidden="true">|</span>
      <span class="status-text">© {uptime} Kai Löhnert</span>
    </div>
    <div class="status-center">
      <a href="/rss.xml" class="status-link" aria-label="RSS feed">rss</a>
      <span class="sep" aria-hidden="true">/</span>
      <a href="https://github.com/luxus" target="_blank" rel="noopener noreferrer" class="status-link" aria-label="GitHub profile">github</a>
      <span class="sep" aria-hidden="true">/</span>
      <a href="https://linkedin.com/in/luxus" target="_blank" rel="noopener noreferrer" class="status-link" aria-label="LinkedIn profile">linkedin</a>
      <span class="sep" aria-hidden="true">/</span>
      <a href="https://twitter.com/luxus" target="_blank" rel="noopener noreferrer" class="status-link" aria-label="Twitter profile">twitter</a>
    </div>
    <div class="status-right">
      <span class="status-text dimmer">built with astro</span>
    </div>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--border);
    background: var(--bg-overlay);
  }

  .status-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    max-width: 860px;
    margin: 0 auto;
    padding: 0.6rem 1.5rem;
    flex-wrap: wrap;
    row-gap: 0.4rem;
  }

  .status-left,
  .status-center,
  .status-right {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .status-indicator {
    display: inline-block;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 6px var(--green-glow);
    animation: pulse 2.5s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 6px var(--green-glow); }
    50%       { opacity: 0.6; box-shadow: 0 0 2px var(--green-glow); }
  }

  .status-text {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-muted);
    letter-spacing: 0.05em;
  }

  .status-text.dimmer { opacity: 0.5; }

  .sep {
    color: var(--border);
    font-size: 0.7rem;
    user-select: none;
  }

  .status-link {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-muted);
    text-decoration: none;
    border-bottom: none;
    letter-spacing: 0.04em;
    transition: color 0.15s, text-shadow 0.15s;
  }

  .status-link:hover {
    color: var(--green);
    text-shadow: 0 0 6px var(--green-glow);
    border-bottom: none;
  }

  @media (max-width: 600px) {
    .status-right { display: none; }
    .status-bar { justify-content: space-between; }
  }

  @media (max-width: 400px) {
    .status-center { display: none; }
  }
</style>

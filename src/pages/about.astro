---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`~/about | ${SITE_TITLE}`} description="About Kai Löhnert — cybersecurity sales professional based in Zürich, Switzerland." />
  </head>
  <body>
    <Header />

    <main>
      <!-- Breadcrumb -->
      <div class="breadcrumb">
        <span class="prompt-char" aria-hidden="true">❯</span>
        <a href="/">~</a>
        <span class="sep" aria-hidden="true">/</span>
        <span class="current">about</span>
      </div>

      <!-- whoami output -->
      <div class="term-window about-window">
        <div class="term-titlebar">
          <span class="term-dot close" aria-hidden="true"></span>
          <span class="term-dot min"   aria-hidden="true"></span>
          <span class="term-dot max"   aria-hidden="true"></span>
          <span class="term-title">whoami &amp;&amp; cat ~/.profile</span>
        </div>

        <div class="about-body">
          <!-- whoami block -->
          <section class="cmd-block">
            <div class="cmd-line" aria-label="Command">
              <span class="prompt">❯</span>
              <span class="cmd">whoami</span>
            </div>
            <div class="cmd-output">
              <div class="output-row">
                <span class="key">name</span>
                <span class="colon">:</span>
                <span class="val">Kai Löhnert</span>
              </div>
              <div class="output-row">
                <span class="key">handle</span>
                <span class="colon">:</span>
                <span class="val amber">@luxus</span>
              </div>
              <div class="output-row">
                <span class="key">role</span>
                <span class="colon">:</span>
                <span class="val">Cybersecurity Sales Professional</span>
              </div>
              <div class="output-row">
                <span class="key">location</span>
                <span class="colon">:</span>
                <span class="val">Zürich, Switzerland 🇨🇭</span>
              </div>
              <div class="output-row">
                <span class="key">origin</span>
                <span class="colon">:</span>
                <span class="val">German 🇩🇪 × Thai 🇹🇭</span>
              </div>
            </div>
          </section>

          <div class="divider" aria-hidden="true"></div>

          <!-- cat ~/.profile block -->
          <section class="cmd-block">
            <div class="cmd-line" aria-label="Command">
              <span class="prompt">❯</span>
              <span class="cmd">cat</span>
              <span class="cmd-file">~/.profile</span>
            </div>
            <div class="cmd-output prose-output">
              <p>
                I work at the intersection of technology and trust — helping organisations in Switzerland and Europe build resilient security postures. With a background spanning both technical architecture and enterprise sales, I translate complex security challenges into business decisions that actually land.
              </p>
              <p>
                Half German, half Thai, raised between two cultures. That mix shaped how I think: direct and precise when it counts, adaptable everywhere else.
              </p>
              <p>
                Currently focused on zero-trust architectures, cloud-native security, and the growing role of AI in threat detection. When I'm not in meetings or on calls, I'm usually building something, writing, or exploring the Swiss mountains.
              </p>
            </div>
          </section>

          <div class="divider" aria-hidden="true"></div>

          <!-- skills block -->
          <section class="cmd-block">
            <div class="cmd-line" aria-label="Command">
              <span class="prompt">❯</span>
              <span class="cmd">cat</span>
              <span class="cmd-file">~/.skills</span>
            </div>
            <div class="cmd-output">
              <div class="skill-grid">
                <div class="skill-group">
                  <span class="skill-label">domain</span>
                  <ul class="skill-list">
                    <li>Cybersecurity sales</li>
                    <li>Zero-trust architecture</li>
                    <li>Cloud security (AWS, Azure)</li>
                    <li>Threat detection & AI</li>
                  </ul>
                </div>
                <div class="skill-group">
                  <span class="skill-label">tools</span>
                  <ul class="skill-list">
                    <li>CRM & pipeline management</li>
                    <li>Security posture assessment</li>
                    <li>Technical presales</li>
                    <li>Stakeholder alignment</li>
                  </ul>
                </div>
                <div class="skill-group">
                  <span class="skill-label">langs</span>
                  <ul class="skill-list">
                    <li>German — native</li>
                    <li>English — fluent</li>
                    <li>Thai — conversational</li>
                  </ul>
                </div>
              </div>
            </div>
          </section>

          <div class="divider" aria-hidden="true"></div>

          <!-- links block -->
          <section class="cmd-block">
            <div class="cmd-line" aria-label="Command">
              <span class="prompt">❯</span>
              <span class="cmd">open</span>
              <span class="cmd-file">--links</span>
            </div>
            <div class="cmd-output links-row">
              <a href="https://github.com/luxus" target="_blank" rel="noopener noreferrer" class="link-item">
                <span class="link-arrow" aria-hidden="true">↗</span>github.com/luxus
              </a>
              <a href="https://linkedin.com/in/luxus" target="_blank" rel="noopener noreferrer" class="link-item">
                <span class="link-arrow" aria-hidden="true">↗</span>linkedin.com/in/luxus
              </a>
              <a href="https://twitter.com/luxus" target="_blank" rel="noopener noreferrer" class="link-item">
                <span class="link-arrow" aria-hidden="true">↗</span>twitter.com/luxus
              </a>
            </div>
          </section>

          <!-- Trailing prompt with cursor -->
          <div class="trailing-prompt" aria-hidden="true">
            <span class="prompt">❯</span>
            <span class="cursor"></span>
          </div>
        </div>
      </div>
    </main>

    <Footer />
  </body>
</html>

<style>
  body {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  main {
    flex: 1;
    max-width: 860px;
    margin: 0 auto;
    width: 100%;
    padding: 2.5rem 1.5rem 4rem;
  }

  /* Breadcrumb */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 1rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }

  .prompt-char {
    color: var(--green);
    font-weight: 700;
    text-shadow: 0 0 8px var(--green-glow);
  }

  .breadcrumb a {
    color: var(--text-muted);
    text-decoration: none;
    border-bottom: none;
    transition: color 0.15s;
  }

  .breadcrumb a:hover {
    color: var(--green);
    border-bottom: none;
    text-shadow: 0 0 6px var(--green-glow);
  }

  .sep { color: var(--border); opacity: 0.6; }

  .current {
    color: var(--green);
    text-shadow: 0 0 6px var(--green-glow);
  }

  /* About window */
  .about-window { overflow: hidden; }

  .about-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* Command block */
  .cmd-block {
    padding: 0.75rem 0;
  }

  .cmd-line {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }

  .prompt {
    color: var(--green);
    font-weight: 700;
    text-shadow: 0 0 6px var(--green-glow);
  }

  .cmd {
    color: var(--amber);
    font-size: 0.8rem;
  }

  .cmd-file {
    color: var(--text-muted);
    font-size: 0.8rem;
  }

  /* Output */
  .cmd-output {
    padding-left: 1.5rem;
    border-left: 2px solid var(--border-dim);
    margin-left: 0.5rem;
  }

  .output-row {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    line-height: 1.8;
  }

  .key {
    color: var(--text-muted);
    min-width: 7ch;
    flex-shrink: 0;
    font-size: 0.75rem;
    letter-spacing: 0.04em;
  }

  .colon {
    color: var(--border);
  }

  .val {
    color: var(--text-bright);
  }

  .val.amber {
    color: var(--amber);
  }

  /* Prose output */
  .prose-output {
    color: var(--text);
    font-size: 0.88rem;
    line-height: 1.8;
    max-width: 68ch;
  }

  .prose-output p {
    margin: 0 0 1em 0;
    text-wrap: pretty;
  }

  .prose-output p:last-child { margin-bottom: 0; }

  /* Skills grid */
  .skill-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .skill-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .skill-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .skill-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .skill-list li {
    font-size: 0.82rem;
    color: var(--text);
    padding-left: 0.75rem;
    position: relative;
  }

  .skill-list li::before {
    content: '─';
    position: absolute;
    left: 0;
    color: var(--green-dim);
    opacity: 0.6;
  }

  /* Links row */
  .links-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.5rem;
  }

  .link-item {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
    text-decoration: none;
    border-bottom: none;
    transition: color 0.15s, text-shadow 0.15s;
  }

  .link-item:hover {
    color: var(--green);
    text-shadow: 0 0 6px var(--green-glow);
    border-bottom: none;
  }

  .link-arrow {
    font-size: 0.7rem;
    opacity: 0.5;
    transition: opacity 0.15s, transform 0.15s;
  }

  .link-item:hover .link-arrow {
    opacity: 1;
    transform: translate(1px, -1px);
  }

  /* Divider */
  .divider {
    height: 1px;
    background: var(--border-dim);
    margin: 0.25rem 0;
  }

  /* Trailing prompt */
  .trailing-prompt {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding-top: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }

  .cursor {
    display: inline-block;
    width: 0.55em;
    height: 0.9em;
    background: var(--green);
    border-radius: 1px;
    vertical-align: text-bottom;
    box-shadow: 0 0 6px var(--green-glow);
    animation: blink 1.1s step-start infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  /* Responsive */
  @media (max-width: 600px) {
    .skill-grid { grid-template-columns: 1fr 1fr; }
    .links-row  { flex-direction: column; gap: 0.5rem; }
  }

  @media (max-width: 420px) {
    main { padding: 1.5rem 1rem 3rem; }
    .skill-grid { grid-template-columns: 1fr; }
    .cmd-output { padding-left: 0.75rem; }
  }
</style>
